ENABLE_SAVE_ON_SERVER=FALSE
DEFAULT_VIDEO_QUALITY=720
FILE_EXPIRATION_SECONDS=300
PORT=5008
# To use cookies from a browser (requires the browser to be closed and installed)
# YT_DLP_COOKIES_BROWSER=chrome
YT_DLP_JS_RUNTIME=node
# Recommended for servers: export cookies from your desktop browser to cookies.txt
YT_DLP_COOKIE_FILE=cookies.txt
